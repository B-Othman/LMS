# ─────────────────────────────────────────────────────────────────────────────
# Securecy LMS — Docker Compose environment
# Copy to infra/docker/.env and fill in values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Laravel app ───────────────────────────────────────────────────────────────
APP_NAME="Securecy LMS"
APP_ENV=local
APP_KEY=                          # Generate with: php artisan key:generate --show
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres                  # Docker service name
DB_PORT=5432
DB_DATABASE=securecy_lms
DB_USERNAME=securecy
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis                  # Docker service name
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Session / Cache / Queue (all Redis) ───────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
CACHE_STORE=redis
CACHE_PREFIX=securecy_
QUEUE_CONNECTION=redis

# ── Mail (Mailpit) ────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit                 # Docker service name
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@securecy.com"
MAIL_FROM_NAME="Securecy LMS"

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
FILESYSTEM_DISK=s3
MEDIA_DISK=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=securecy-lms
AWS_ENDPOINT=http://minio:9000    # Docker service name
AWS_USE_PATH_STYLE_ENDPOINT=true
MEDIA_SIGNED_URL_EXPIRY_MINUTES=15

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001
SANCTUM_TOKEN_EXPIRY=1440         # minutes (24 hours)

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME="Securecy LMS"
