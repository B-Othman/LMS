APP_NAME="Securecy LMS"
APP_ENV=local
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=securecy_lms
DB_USERNAME=securecy
DB_PASSWORD=secret

# --- Redis ---
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Session (Redis) ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Cache (Redis) ---
CACHE_STORE=redis
CACHE_PREFIX=securecy_

# --- Queue (Redis) ---
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

# --- Mail ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@securecy.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3-compatible Object Storage ---
MEDIA_DISK=s3
MEDIA_SIGNED_URL_EXPIRY_MINUTES=15
MEDIA_IMAGE_THUMBNAIL_WIDTH=360
MEDIA_IMAGE_THUMBNAIL_QUALITY=82
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=securecy-lms
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,127.0.0.1,127.0.0.1:*,::1
SANCTUM_TOKEN_EXPIRY=1440         # minutes — 24 hours
